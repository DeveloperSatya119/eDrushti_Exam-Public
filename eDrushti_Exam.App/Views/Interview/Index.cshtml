@model List<eDrushti_Exam.App.Models.Topic>
@{
    ViewData["Title"] = "Interview";
    Layout = null; /* full-screen — no shared nav */
    string trackName    = ViewBag.TrackName     ?? "Interview";
    string candidateName = ViewBag.CandidateName ?? "Candidate";
    bool isPhotoRequired = ViewBag.IsPhotoRequired ?? false;
    bool hasPhoto = ViewBag.HasPhoto ?? false;
    int    totalQ       = Model.Sum(t => t.Questions.Count);
    var    allQ         = Model.SelectMany(t => t.Questions).ToList();
    var draftAnswers    = ViewBag.DraftAnswers as Dictionary<int, string> ?? new();
}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>@trackName Interview — eDrushti</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}

:root{
  --bg:    #ffffff;
  --bg2:   #f8f9fa;
  --bg3:   #f1f3f5;
  --bg4:   #e9ecef;
  --line:  #dee2e6;
  --line2: #ced4da;
  --green: #2f9e44;
  --green2:#2f9e44;
  --blue:  #1971c2;
  --yellow:#e67700;
  --red:   #c92a2a;
  --text:  #1a1a1a;
  --muted: #495057;
  --dim:   #868e96;
  --mono:  'Inter', sans-serif;
  --sans:  'Inter', sans-serif;
  --hdr:   52px;
  --side:  264px;
}

html,body { height:100%; overflow:hidden; background:var(--bg); color:var(--text); font-family:var(--sans); font-size:15px; }

/* ══════════════════════════ TOP BAR ════════════════════════════════════════ */
.topbar {
  position:fixed; top:0; left:0; right:0; height:var(--hdr); z-index:400;
  background:#ffffff; border-bottom:1px solid var(--line);
  display:flex; align-items:center; padding:0 1.25rem; gap:1rem;
  box-shadow:0 1px 4px rgba(0,0,0,.06);
}
.tb-brand {
  display:flex; align-items:center; gap:.55rem;
  font-family:var(--sans); font-size:.82rem; font-weight:700;
  color:var(--text); white-space:nowrap; flex-shrink:0;
}
.tb-pulse {
  width:8px; height:8px; border-radius:50%; background:var(--green);
  box-shadow:0 0 0 0 rgba(57,211,83,.5);
  animation:pulse-ring 2s ease infinite;
}
@@keyframes pulse-ring {
  0%   { box-shadow:0 0 0 0 rgba(57,211,83,.5); }
  70%  { box-shadow:0 0 0 6px rgba(57,211,83,0); }
  100% { box-shadow:0 0 0 0 rgba(57,211,83,0); }
}
.tb-track-badge {
  font-size:.67rem; padding:2px 9px; border-radius:4px;
  background:#e7f5ff; border:1px solid #a5d8ff;
  color:var(--blue); font-family:var(--sans); font-weight:700; letter-spacing:.04em;
}

/* progress (centre) */
.tb-mid { flex:1; display:flex; align-items:center; justify-content:center; gap:.85rem; }
.tb-prog-wrap { display:flex; align-items:center; gap:.6rem; }
.tb-prog-bar { width:200px; height:3px; background:#dee2e6; border-radius:99px; overflow:hidden; }
.tb-prog-fill { height:100%; background:var(--green); border-radius:99px; transition:width .35s ease; }
.tb-prog-txt { font-family:var(--sans); font-size:.72rem; color:var(--muted); white-space:nowrap; }
#tb-done { color:var(--green); font-weight:700; }

/* timer */
.tb-timer {
  display:flex; align-items:center; gap:.45rem;
  background:var(--bg3); border:1px solid var(--line);
  border-radius:6px; padding:.28rem .8rem;
  font-family:var(--sans); font-size:.88rem; font-weight:700; color:var(--text);
  flex-shrink:0;
}
.tb-timer.warn  #tb-time { color:var(--yellow); }
.tb-timer.crit  #tb-time { color:var(--red); animation:blink .75s step-end infinite; }
@@keyframes blink { 50%{ opacity:.35; } }

/* right */
.tb-right { display:flex; align-items:center; gap:.65rem; flex-shrink:0; }
.tb-user { font-size:.78rem; color:var(--muted); }
.tb-user strong { color:var(--text); font-weight:500; }
.tb-sep { width:1px; height:20px; background:var(--line); }
.tb-submit {
  display:flex; align-items:center; gap:.4rem;
  background:var(--green2); color:#fff; border:none; border-radius:6px;
  font-family:var(--sans); font-size:.8rem; font-weight:600;
  padding:.38rem 1rem; cursor:pointer; transition:background .15s;
  white-space:nowrap;
}
.tb-submit:hover { background:#2b8a3e; }

/* ══════════════════════════ SHELL ══════════════════════════════════════════ */
.shell {
  display:grid; grid-template-columns:var(--side) 1fr;
  height:100vh; padding-top:var(--hdr);
}

/* ══════════════════════════ LEFT NAV ═══════════════════════════════════════ */
.qnav {
  background:#fafbfc; border-right:1px solid var(--line);
  display:flex; flex-direction:column; overflow:hidden;
}
.qnav-hdr {
  padding:.7rem 1rem; border-bottom:1px solid var(--line);
  display:flex; align-items:center; justify-content:space-between;
  background:#ffffff;
}
.qnav-hdr-label {
  font-size:.65rem; font-weight:700; text-transform:uppercase;
  letter-spacing:.1em; color:var(--dim); font-family:var(--sans);
}
.qnav-hdr-count { font-family:var(--sans); font-size:.7rem; color:var(--muted); }

.qnav-body { flex:1; overflow-y:auto; padding:.35rem 0; }
.qnav-body::-webkit-scrollbar { width:3px; }
.qnav-body::-webkit-scrollbar-thumb { background:#ced4da; border-radius:2px; }

.qnav-section { margin-bottom:.2rem; }
.qnav-section-hdr {
  padding:.5rem 1rem .2rem;
  font-size:.62rem; font-weight:700; text-transform:uppercase;
  letter-spacing:.1em; color:var(--dim); font-family:var(--sans);
  display:flex; align-items:center; gap:.5rem;
}
.qnav-section-hdr::after { content:''; flex:1; height:1px; background:var(--line); }

.qnav-row { display:flex; align-items:center; gap:.6rem; padding:.38rem 1rem; cursor:pointer; font-size:.78rem; color:var(--muted); border-left:2px solid transparent; transition:all .1s; text-decoration:none; }
.qnav-row:hover { background:var(--bg3); color:var(--text); }
.qnav-row.active { background:#e7f5ff; color:var(--blue); border-left-color:var(--blue); }
.qnav-row.done { color:var(--green); }
.qnav-row.done .qnav-dot { background:var(--green); border-color:var(--green); }
.qnav-row.active.done { color:var(--blue); }

.qnav-idx { font-family:var(--sans); font-size:.7rem; font-weight:600; min-width:20px; color:inherit; }
.qnav-snippet { flex:1; font-size:.76rem; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.qnav-dot {
  width:6px; height:6px; border-radius:50%; flex-shrink:0;
  background:transparent; border:1.5px solid var(--line2);
  transition:all .15s;
}

/* ══════════════════════════ QUESTION PANEL ═════════════════════════════════ */
.qpanel {
  display:flex; flex-direction:column;
  background:var(--bg); overflow:hidden;
}

/* panel top strip */
.qpanel-strip {
  background:#ffffff; border-bottom:1px solid var(--line);
  padding:.55rem 1.5rem;
  display:flex; align-items:center; gap:.75rem; flex-shrink:0;
}
.qpanel-badge {
  font-family:var(--sans); font-size:.68rem; font-weight:700;
  background:#e7f5ff; border:1px solid #a5d8ff;
  border-radius:5px; padding:2px 9px; color:var(--blue); flex-shrink:0;
}
.qpanel-topic-tag {
  font-size:.68rem; color:var(--muted); font-family:var(--sans);
  background:var(--bg3); border:1px solid var(--line);
  border-radius:4px; padding:2px 8px;
}
.qpanel-arrows { margin-left:auto; display:flex; gap:.35rem; }
.arrow-btn {
  background:var(--bg); border:1px solid var(--line); border-radius:5px;
  color:var(--muted); font-size:.75rem; padding:.26rem .6rem; cursor:pointer;
  font-family:var(--sans); transition:all .12s; display:flex; align-items:center; gap:.25rem;
}
.arrow-btn:hover:not(:disabled) { background:var(--bg3); color:var(--text); border-color:var(--line2); }
.arrow-btn:disabled { opacity:.3; cursor:not-allowed; }

/* scrollable body */
.qpanel-body { flex:1; overflow-y:auto; }
.qpanel-body::-webkit-scrollbar { width:5px; }
.qpanel-body::-webkit-scrollbar-track { background:#ffffff; }
.qpanel-body::-webkit-scrollbar-thumb { background:#ced4da; border-radius:3px; }

.qpanel-inner { padding:2rem 2.25rem; display:flex; flex-direction:column; min-height:100%; }

/* question text */
.q-num-row { display:flex; align-items:center; gap:.75rem; margin-bottom:1.25rem; }
.q-num-tag {
  font-family:var(--sans); font-size:.68rem; font-weight:700;
  color:var(--green); background:#ebfbee;
  border:1px solid #b2f2bb; border-radius:4px; padding:2px 9px;
}
.q-difficulty { font-size:.68rem; color:var(--dim); font-family:var(--sans); }

.q-body {
  font-size:.975rem; line-height:1.8; color:var(--text);
  margin-bottom:1.5rem; font-weight:400;
}

/* hint box */
.q-hint-box {
  display:flex; gap:.65rem; align-items:flex-start;
  background:#fff9db; border:1px solid #ffe066;
  border-radius:8px; padding:.8rem 1rem; margin-bottom:1.5rem;
  font-size:.82rem; color:#7c4a00; line-height:1.55;
}
.q-hint-icon { font-size:.95rem; flex-shrink:0; margin-top:1px; }

/* answer section */
.q-answer-hdr {
  display:flex; align-items:center; justify-content:space-between;
  margin-bottom:.55rem;
}
.q-answer-label {
  font-size:.65rem; font-weight:600; text-transform:uppercase;
  letter-spacing:.1em; color:var(--dim); font-family:var(--sans);
}
.q-cc { font-family:var(--sans); font-size:.68rem; color:var(--dim); }
.q-cc.near { color:var(--yellow); }
.q-cc.over { color:var(--red); }

.q-textarea {
  width:100%; min-height:230px;
  background:#ffffff; border:1px solid var(--line2);
  border-radius:8px; color:var(--text);
  font-family:var(--sans); font-size:.9rem; line-height:1.7;
  padding:.95rem 1.1rem; resize:vertical; outline:none;
  transition:border-color .15s, box-shadow .15s;
}
.q-textarea:focus {
  border-color:var(--blue);
  box-shadow:0 0 0 3px rgba(25,113,194,.08);
}
.q-textarea::placeholder { color:#adb5bd; }
.q-textarea.filled { border-color:#a9e34b; background:#fff; }

.q-autosave {
  display:flex; align-items:center; gap:.3rem;
  font-size:.68rem; color:var(--dim); font-family:var(--sans);
  margin-top:.45rem; opacity:0; transition:opacity .3s;
}
.q-autosave.show { opacity:1; }
.q-autosave svg { color:var(--green); }

/* ══ footer bar ══ */
.qpanel-foot {
  background:#ffffff; border-top:1px solid var(--line);
  padding:.65rem 1.5rem; flex-shrink:0;
  display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:.5rem;
}
.foot-info { font-size:.75rem; color:var(--muted); }
.foot-info b { color:var(--text); font-family:var(--sans); font-weight:600; }
.foot-btns { display:flex; gap:.4rem; }

.btn {
  display:inline-flex; align-items:center; gap:.3rem;
  padding:.38rem .85rem; border-radius:6px; font-family:var(--sans);
  font-size:.78rem; font-weight:500; cursor:pointer;
  border:1px solid transparent; transition:all .15s; text-decoration:none;
}
.btn-ghost  { background:transparent; color:var(--muted); border-color:var(--line); }
.btn-ghost:hover  { background:var(--bg3); color:var(--text); border-color:var(--line2); }
.btn-blue   { background:#e7f5ff; color:var(--blue); border-color:#a5d8ff; }
.btn-blue:hover   { background:#d0ebff; }
.btn-green  { background:var(--green2); color:#fff; border-color:var(--green2); }
.btn-green:hover  { background:#2b8a3e; }
.save-state{font-size:.72rem;color:var(--muted);align-self:center}
.save-state.ok{color:var(--green)}
.save-state.err{color:var(--red)}

/* ══════════════════════════ CONFIRM OVERLAY ════════════════════════════════ */
.overlay {
  display:none; position:fixed; inset:0; z-index:999;
  background:rgba(0,0,0,.45); backdrop-filter:blur(4px);
  align-items:center; justify-content:center; padding:1.5rem;
}
.overlay.open { display:flex; }

.cfm-box {
  background:#ffffff; border:1px solid var(--line);
  border-radius:12px; width:100%; max-width:460px;
  animation:pop-in .2s cubic-bezier(.34,1.4,.64,1);
  box-shadow:0 20px 60px rgba(0,0,0,.15);
}
@@keyframes pop-in { from{opacity:0;transform:scale(.9) translateY(10px)} to{opacity:1;transform:none} }

.cfm-hdr {
  padding:1.25rem 1.5rem; border-bottom:1px solid var(--line);
  display:flex; align-items:center; gap:.85rem;
}
.cfm-icon {
  width:40px; height:40px; border-radius:8px; flex-shrink:0;
  background:#ebfbee; border:1px solid #b2f2bb;
  display:flex; align-items:center; justify-content:center; font-size:1.2rem;
}
.cfm-title { font-size:.975rem; font-weight:700; margin-bottom:.15rem; color:var(--text); }
.cfm-sub { font-size:.78rem; color:var(--muted); }

.cfm-body { padding:1.25rem 1.5rem; }
.cfm-stats {
  display:grid; grid-template-columns:repeat(3,1fr); gap:.75rem; margin-bottom:1.25rem;
}
.cfm-stat {
  background:var(--bg3); border:1px solid var(--line);
  border-radius:8px; padding:.85rem; text-align:center;
}
.cfm-stat-val { font-family:var(--sans); font-size:1.5rem; font-weight:700; line-height:1; margin-bottom:.25rem; }
.cfm-stat-lbl { font-size:.65rem; color:var(--muted); text-transform:uppercase; letter-spacing:.06em; font-family:var(--sans); }

.cfm-warn {
  background:#fff5f5; border:1px solid #ffc9c9;
  border-radius:7px; padding:.7rem .9rem; font-size:.8rem; color:#c92a2a;
  margin-bottom:1rem; display:none; line-height:1.5;
}
.cfm-note { font-size:.78rem; color:var(--muted); line-height:1.6; }

.cfm-foot {
  padding:1rem 1.5rem; border-top:1px solid var(--line);
  display:flex; gap:.5rem; justify-content:flex-end;
}

/* keyboard hint */
.kb-hint {
  font-size:.65rem; color:var(--dim); font-family:var(--sans);
  display:flex; gap:1rem; flex-wrap:wrap; padding:.5rem 0 0;
}
.kb-hint span { display:flex; align-items:center; gap:.3rem; }
kbd {
  background:#f1f3f5; border:1px solid var(--line2);
  border-radius:3px; padding:1px 5px; font-family:var(--sans);
  font-size:.63rem; color:var(--muted);
}

/* ══ MCQ OPTIONS ════════════════════════════════════════════════════════════ */
.mcq-options { display:flex; flex-direction:column; gap:.65rem; margin-bottom:1.25rem; }

.mcq-option {
  display:flex; align-items:flex-start; gap:.85rem;
  padding:.85rem 1rem;
  border:1.5px solid var(--line2);
  border-radius:10px;
  cursor:pointer;
  transition:all .15s;
  background:#fff;
  user-select:none;
}
.mcq-option:hover { border-color:var(--blue); background:#f8fbff; }
.mcq-option.selected {
  border-color:var(--blue);
  background:#e7f5ff;
}
.mcq-option.selected .mcq-letter {
  background:var(--blue);
  color:#fff;
  border-color:var(--blue);
}

.mcq-letter {
  width:28px; height:28px; border-radius:50%;
  display:flex; align-items:center; justify-content:center;
  font-size:.75rem; font-weight:700;
  border:1.5px solid var(--line2);
  color:var(--muted);
  flex-shrink:0;
  transition:all .15s;
  margin-top:1px;
}
.mcq-text {
  font-size:.9rem;
  line-height:1.55;
  color:var(--text);
  flex:1;
}

/* question type badge */
.q-type-badge {
  display:inline-flex; align-items:center; gap:.3rem;
  font-size:.65rem; font-weight:700; padding:2px 9px;
  border-radius:99px; letter-spacing:.04em;
}
.q-type-mcq       { background:#fff3bf; color:#7c4a00; border:1px solid #ffe066; }
.q-type-coding    { background:#e8f4fd; color:#1971c2; border:1px solid #a5d8ff; }
.q-type-short     { background:#ebfbee; color:#2f9e44; border:1px solid #b2f2bb; }

.photo-modal .cfm-box{max-width:680px}
.photo-stage{display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1rem}
.photo-stage video,.photo-stage canvas{width:100%;aspect-ratio:4/3;background:#111;border:1px solid var(--line2);border-radius:10px;object-fit:cover}
.photo-consent{display:flex;gap:.6rem;align-items:flex-start;background:#f8f9fa;border:1px solid var(--line);border-radius:8px;padding:.75rem .9rem;font-size:.8rem;color:var(--muted);line-height:1.5}
.photo-consent input{margin-top:3px;accent-color:var(--blue)}
.photo-error{display:none;color:var(--red);background:#fff5f5;border:1px solid #ffc9c9;border-radius:7px;padding:.6rem .8rem;font-size:.8rem;margin-top:.75rem}
.photo-actions{display:flex;gap:.5rem;justify-content:flex-end;flex-wrap:wrap}
.capture-required-lock .qpanel{filter:blur(2px);pointer-events:none}

@@media(max-width:768px){
  .shell { grid-template-columns:1fr; }
  .qnav  { display:none; }
}
</style>
</head>
<body>

<!-- ══ TOP BAR ══════════════════════════════════════════════════════════════ -->
<header class="topbar">
  <div class="tb-brand">
    <span class="tb-pulse"></span>
    eDrushti
    <span class="tb-track-badge">@trackName.ToUpper()</span>
  </div>

  <div class="tb-mid">
    <div class="tb-prog-wrap">
      <span class="tb-prog-txt"><span id="tb-done">0</span> / @totalQ answered</span>
      <div class="tb-prog-bar">
        <div class="tb-prog-fill" id="tb-fill" style="width:0%"></div>
      </div>
    </div>
  </div>

  <div class="tb-right">
    <div class="tb-timer" id="tb-timer">
      <svg width="13" height="13" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
        <circle cx="8" cy="8" r="6.5"/><path d="M8 4V8l2.5 2" stroke-linecap="round"/>
      </svg>
      <span id="tb-time">90:00</span>
    </div>
    <div class="tb-sep"></div>
    <span class="tb-user">Hi, <strong>@candidateName</strong></span>
    <button class="tb-submit" onclick="openConfirm()">
      Submit Test &rarr;
    </button>
  </div>
</header>

<!-- ══ SHELL ═════════════════════════════════════════════════════════════════ -->
<div class="shell">

  <!-- LEFT NAV ─────────────────────────────────────────────────────────────── -->
  <nav class="qnav">
    <div class="qnav-hdr">
      <span class="qnav-hdr-label">Questions</span>
      <span class="qnav-hdr-count" id="nav-count">0 / @totalQ</span>
    </div>
    <div class="qnav-body">
      @{ int ni = 0; }
      @foreach (var topic in Model)
      {
        <div class="qnav-section">
          <div class="qnav-section-hdr">@topic.Name</div>
          @foreach (var q in topic.Questions)
          {
            ni++;
            var snippet = q.QuestionText.Length > 36
                ? q.QuestionText.Substring(0, 36) + "…"
                : q.QuestionText;
            <a class="qnav-row" id="nav-@q.Id"
               href="#" onclick="jumpTo(@q.Id, @(ni-1)); return false;">
              <span class="qnav-idx">@(ni.ToString("D2"))</span>
              <span class="qnav-snippet">@snippet</span>
              <span class="qnav-dot" id="ndot-@q.Id"></span>
            </a>
          }
        </div>
      }
    </div>
  </nav>

  <!-- QUESTION PANEL ─────────────────────────────────────────────────────── -->
  <div class="qpanel">

    <!-- strip -->
    <div class="qpanel-strip">
      <span class="qpanel-badge" id="s-num">Q 01</span>
      <span class="qpanel-topic-tag" id="s-topic">—</span>
      <div class="qpanel-arrows">
        <button class="arrow-btn" id="btn-prev" onclick="navigate(-1)" disabled>
          &#8592; Prev
        </button>
        <button class="arrow-btn" id="btn-next" onclick="navigate(1)">
          Next &#8594;
        </button>
      </div>
    </div>

    <!-- hidden form — holds all answers on submit -->
    <form id="iv-form" method="post" asp-action="Submit" asp-controller="Interview" style="display:none">
      @Html.AntiForgeryToken()
      @foreach (var q in allQ)
      {
        <textarea name="answers[@q.Id]" id="h-@q.Id"></textarea>
      }
    </form>

    <!-- body -->
    <div class="qpanel-body">
      <div class="qpanel-inner">

        <div class="q-num-row">
          <span class="q-num-tag" id="q-num-tag">Question 01</span>
          <span class="q-difficulty" id="q-topic-label">—</span>
          <span class="q-type-badge" id="q-type-badge"></span>
        </div>

        <!-- Question text — for MCQ only the stem (before options) -->
        <p class="q-body" id="q-body">Loading question…</p>

        <!-- Hint box -->
        <div class="q-hint-box" id="q-hint" style="display:none">
          <span class="q-hint-icon">💡</span>
          <span id="q-hint-txt"></span>
        </div>

        <!-- ══ MCQ OPTIONS (shown only for MCQ questions) ══ -->
        <div class="mcq-options" id="mcq-options" style="display:none"></div>

        <!-- ══ TEXT ANSWER (shown for Coding / Short Answer) ══ -->
        <div id="text-answer-wrap">
          <div class="q-answer-hdr">
            <span class="q-answer-label" id="answer-label">Your Answer</span>
            <span class="q-cc" id="q-cc">0 / 3000</span>
          </div>
          <textarea class="q-textarea" id="q-input"
            placeholder="Write your answer here…&#10;&#10;Tips:&#10;• Use specific examples to support your points&#10;• Explain concepts in your own words&#10;• Mention tradeoffs where relevant"
            maxlength="3000"
            oninput="onType(this)"></textarea>
          <div class="q-autosave" id="q-saved">
            <svg width="11" height="11" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M2 6l3 3 5-5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            draft saved
          </div>
        </div>

        <div class="kb-hint" style="margin-top:1.5rem">
          <span><kbd>Alt</kbd>+<kbd>→</kbd> next question</span>
          <span><kbd>Alt</kbd>+<kbd>←</kbd> previous</span>
          <span><kbd>Alt</kbd>+<kbd>Enter</kbd> submit</span>
        </div>

      </div>
    </div>

    <!-- footer -->
    <div class="qpanel-foot">
      <div class="foot-info">
        Question <b id="f-cur">1</b> of <b>@totalQ</b>
        &nbsp;&middot;&nbsp;
        <b id="f-ans">0</b> answered
        &nbsp;&middot;&nbsp;
        <b id="f-rem">@totalQ</b> remaining
      </div>
  <div class="foot-btns">
        @if (isPhotoRequired && !hasPhoto)
        {
          <button class="btn btn-blue" id="btn-photo-capture" onclick="openPhotoModal()">Capture Photo &amp; Consent</button>
        }
        <span class="save-state" id="save-state"></span>
        <button class="btn btn-blue" onclick="saveProgress()">Save Progress</button>
        <button class="btn btn-ghost" onclick="clearAnswer()">Clear</button>
        <button class="btn btn-blue"  onclick="navigate(1)"   id="btn-next2">Next &rarr;</button>
      </div>
    </div>

  </div><!-- /qpanel -->
</div><!-- /shell -->

<!-- ══ CONFIRM OVERLAY ══════════════════════════════════════════════════════ -->
<div class="overlay" id="overlay">
  <div class="cfm-box">
    <div class="cfm-hdr">
      <div class="cfm-icon">🚀</div>
      <div>
        <div class="cfm-title">Submit your test?</div>
        <div class="cfm-sub">This is final — answers cannot be changed after submission.</div>
      </div>
    </div>
    <div class="cfm-body">
      <div class="cfm-stats">
        <div class="cfm-stat">
          <div class="cfm-stat-val" style="color:var(--blue)">@totalQ</div>
          <div class="cfm-stat-lbl">Total</div>
        </div>
        <div class="cfm-stat">
          <div class="cfm-stat-val" id="cf-ans" style="color:var(--green)">0</div>
          <div class="cfm-stat-lbl">Answered</div>
        </div>
        <div class="cfm-stat">
          <div class="cfm-stat-val" id="cf-skip" style="color:var(--yellow)">@totalQ</div>
          <div class="cfm-stat-lbl">Skipped</div>
        </div>
      </div>
      <div class="cfm-warn" id="cf-warn">
        ⚠&nbsp; You still have unanswered questions. You can go back and complete them.
      </div>
      <p class="cfm-note">
        Once confirmed, your responses will be locked and forwarded to the review team.
        Ensure you are satisfied before proceeding.
      </p>
    </div>
    <div class="cfm-foot">
      <button class="btn btn-ghost" onclick="closeConfirm()">Go back</button>
      <button class="btn btn-green" onclick="doSubmit()">Confirm &amp; Submit &rarr;</button>
    </div>
  </div>
</div>

<!-- ══ PHOTO CONSENT / CAPTURE ═════════════════════════════════════════════ -->
@if (isPhotoRequired && !hasPhoto)
{
  <div class="overlay photo-modal" id="photo-overlay">
    <div class="cfm-box">
      <div class="cfm-hdr">
        <div class="cfm-icon">📷</div>
        <div>
          <div class="cfm-title">Photo verification required</div>
          <div class="cfm-sub">Capture your photo while holding any ID proof before starting the test.</div>
        </div>
      </div>
      <div class="cfm-body">
        <div class="photo-stage">
          <video id="photo-video" autoplay playsinline muted></video>
          <canvas id="photo-canvas"></canvas>
        </div>
        <label class="photo-consent">
          <input type="checkbox" id="photo-consent"/>
          <span>I agree that my photo with ID proof will be captured and stored for interview verification.</span>
        </label>
        <div class="photo-error" id="photo-error"></div>
      </div>
      <div class="cfm-foot photo-actions">
        <button class="btn btn-ghost" id="photo-retake" onclick="retakePhoto()" disabled>Retake</button>
        <button class="btn btn-blue" onclick="capturePhoto()">Capture</button>
        <button class="btn btn-green" id="photo-save" onclick="savePhoto()" disabled>Save &amp; Start Test</button>
      </div>
    </div>
  </div>
}

<script>
// ── Data ──────────────────────────────────────────────────────────────────────
const PHOTO_REQUIRED = @(isPhotoRequired.ToString().ToLowerInvariant());
let PHOTO_SAVED = @(hasPhoto.ToString().ToLowerInvariant());
let photoStream = null;
let capturedPhotoDataUrl = '';
const QUESTIONS = [
  @foreach (var topic in Model)
  {
    foreach (var q in topic.Questions)
    {
      @:{ id:@q.Id, text:@Html.Raw(System.Text.Json.JsonSerializer.Serialize(q.QuestionText)), hint:@Html.Raw(System.Text.Json.JsonSerializer.Serialize(q.HintText??"")), topic:@Html.Raw(System.Text.Json.JsonSerializer.Serialize(topic.Name)), type:@Html.Raw(System.Text.Json.JsonSerializer.Serialize(q.QuestionType)), options:{ A:@Html.Raw(System.Text.Json.JsonSerializer.Serialize(q.OptionA??"")), B:@Html.Raw(System.Text.Json.JsonSerializer.Serialize(q.OptionB??"")), C:@Html.Raw(System.Text.Json.JsonSerializer.Serialize(q.OptionC??"")), D:@Html.Raw(System.Text.Json.JsonSerializer.Serialize(q.OptionD??"")) } },
    }
  }
];
const DRAFT_ANSWERS = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(draftAnswers));
const TOTAL   = @totalQ;
const answers = {};
let   cur     = 0;
let   saveT   = null;

Object.entries(DRAFT_ANSWERS).forEach(([questionId, value]) => {
  if (value && value.trim()) answers[Number(questionId)] = value;
});

// ── Detect question type ──────────────────────────────────────────────────────
// Returns: 'mcq' | 'coding' | 'text'
function getType(q) {
  const explicitType = (q.type || '').toLowerCase();
  if (explicitType === 'mcq') return 'mcq';
  if (explicitType === 'coding') return 'coding';
  const t = q.topic.toLowerCase();
  if (t === 'coding') return 'coding';
  return 'text';
}

// ── Parse MCQ options from question text ──────────────────────────────────────
// Looks for patterns like (A) ... (B) ... or A) ... B) ...
function parseMCQ(text) {
  // Split on option markers: (A), (B), (C), (D) or A) B) C) D)
  const regex = /\(([A-D])\)\s*/g;
  const parts = text.split(/\([A-D]\)\s*/);
  const labels = [...text.matchAll(/\(([A-D])\)/g)].map(m => m[1]);

  if (labels.length < 2) return null; // not a standard MCQ

  const stem    = parts[0].trim();
  const options = labels.map((lbl, i) => ({
    label: lbl,
    text:  (parts[i + 1] || '').trim()
  }));

  return { stem, options };
}

// ── Render ────────────────────────────────────────────────────────────────────
function render(i) {
  if (i < 0 || i >= TOTAL) return;
  const q    = QUESTIONS[i];
  const type = getType(q);
  cur = i;

  // strip badges
  document.getElementById('s-num').textContent          = `Q ${String(i+1).padStart(2,'0')}`;
  document.getElementById('s-topic').textContent        = q.topic;
  document.getElementById('q-num-tag').textContent      = `Question ${String(i+1).padStart(2,'0')}`;
  document.getElementById('q-topic-label').textContent  = q.topic;

  // type badge
  const typeBadge = document.getElementById('q-type-badge');
  if (type === 'mcq') {
    typeBadge.textContent  = '⊙ Multiple Choice';
    typeBadge.className    = 'q-type-badge q-type-mcq';
  } else if (type === 'coding') {
    typeBadge.textContent  = '⌨ Coding';
    typeBadge.className    = 'q-type-badge q-type-coding';
  } else {
    typeBadge.textContent  = '✍ Short Answer';
    typeBadge.className    = 'q-type-badge q-type-short';
  }

  // hint
  const hb = document.getElementById('q-hint');
  if (q.hint) { document.getElementById('q-hint-txt').textContent = q.hint; hb.style.display = 'flex'; }
  else        { hb.style.display = 'none'; }

  const mcqWrap  = document.getElementById('mcq-options');
  const textWrap = document.getElementById('text-answer-wrap');
  const qBody    = document.getElementById('q-body');

  if (type === 'mcq') {
    // ── MCQ rendering ──
    const optionEntries = Object.entries(q.options || {}).filter(([, text]) => text && text.trim());
    const parsed = optionEntries.length >= 2
      ? { stem: q.text, options: optionEntries.map(([label, text]) => ({ label, text })) }
      : parseMCQ(q.text);

    if (parsed) {
      qBody.textContent       = parsed.stem;
      mcqWrap.style.display   = 'flex';
      textWrap.style.display  = 'none';

      // build option cards
      const saved = answers[q.id] || '';
      mcqWrap.innerHTML = parsed.options.map(opt => `
        <div class="mcq-option ${saved === opt.label ? 'selected' : ''}"
             onclick="selectOption(${q.id}, '${opt.label}', this)">
          <span class="mcq-letter">${opt.label}</span>
          <span class="mcq-text">${opt.text}</span>
        </div>
      `).join('');
    } else {
      // fallback: show as text if parsing fails
      qBody.textContent      = q.text;
      mcqWrap.style.display  = 'none';
      textWrap.style.display = 'block';
      renderTextAnswer(q, type);
    }

  } else {
    // ── Text / Coding rendering ──
    qBody.textContent      = q.text;
    mcqWrap.style.display  = 'none';
    textWrap.style.display = 'block';
    renderTextAnswer(q, type);
  }

  // nav highlight
  document.querySelectorAll('.qnav-row').forEach(r => r.classList.remove('active'));
  const nr = document.getElementById(`nav-${q.id}`);
  if (nr) { nr.classList.add('active'); nr.scrollIntoView({ block: 'nearest', behavior: 'smooth' }); }

  // buttons
  document.getElementById('btn-prev').disabled  = i === 0;
  document.getElementById('btn-next').disabled  = i === TOTAL - 1;
  document.getElementById('btn-next2').disabled = i === TOTAL - 1;
  document.getElementById('f-cur').textContent  = i + 1;
}

// ── Render text answer area ───────────────────────────────────────────────────
function renderTextAnswer(q, type) {
  const ta = document.getElementById('q-input');
  ta.value = answers[q.id] || '';
  ta.classList.toggle('filled', !!(answers[q.id]));
  updateCC(ta.value.length);
  document.getElementById('q-saved').classList.remove('show');

  const label = document.getElementById('answer-label');
  if (type === 'coding') {
    ta.placeholder = 'Write your code here…\n\n• Use proper indentation\n• Add comments to explain your logic\n• Mention time and space complexity';
    label.textContent = 'Your Code';
  } else {
    ta.placeholder = 'Write your answer here…\n\nTips:\n• Use specific examples to support your points\n• Explain concepts in your own words\n• Mention tradeoffs where relevant';
    label.textContent = 'Your Answer';
  }
}

// ── MCQ option selection ──────────────────────────────────────────────────────
function selectOption(qId, label, el) {
  // deselect all options for this question
  document.querySelectorAll('.mcq-option').forEach(o => o.classList.remove('selected'));
  el.classList.add('selected');

  // store answer
  answers[qId] = label;
  document.getElementById(`h-${qId}`).value = label;

  // update nav dot
  const nd = document.getElementById(`ndot-${qId}`);
  const nr = document.getElementById(`nav-${qId}`);
  if (nd) { nd.style.background = 'var(--green)'; nd.style.borderColor = 'var(--green)'; }
  nr?.classList.add('done');

  updateSummary();
}

// ── Textarea type handler ─────────────────────────────────────────────────────
function onType(el) {
  const q = QUESTIONS[cur];
  answers[q.id] = el.value;
  document.getElementById(`h-${q.id}`).value = el.value;
  el.classList.toggle('filled', el.value.trim().length > 0);
  updateCC(el.value.length);

  const nd  = document.getElementById(`ndot-${q.id}`);
  const nr  = document.getElementById(`nav-${q.id}`);
  const has = el.value.trim().length > 0;
  if (nd) { nd.style.background = has ? 'var(--green)' : ''; nd.style.borderColor = has ? 'var(--green)' : ''; }
  nr?.classList.toggle('done', has);

  updateSummary();

  clearTimeout(saveT);
  document.getElementById('q-saved').classList.remove('show');
  if (el.value.trim()) saveT = setTimeout(() => document.getElementById('q-saved').classList.add('show'), 900);
}

function updateCC(len) {
  const el = document.getElementById('q-cc');
  el.textContent = `${len} / 3000`;
  el.className = 'q-cc' + (len > 2700 ? ' over' : len > 2400 ? ' near' : '');
}

function updateSummary() {
  const done = Object.values(answers).filter(v => v && v.trim().length > 0).length;
  const pct  = done / TOTAL * 100;
  document.getElementById('tb-fill').style.width   = pct + '%';
  document.getElementById('tb-done').textContent   = done;
  document.getElementById('nav-count').textContent = `${done} / ${TOTAL}`;
  document.getElementById('f-ans').textContent     = done;
  document.getElementById('f-rem').textContent     = TOTAL - done;
}

function markAnswered(questionId, hasAnswer) {
  const nd = document.getElementById(`ndot-${questionId}`);
  const nr = document.getElementById(`nav-${questionId}`);
  if (nd) {
    nd.style.background = hasAnswer ? 'var(--green)' : '';
    nd.style.borderColor = hasAnswer ? 'var(--green)' : '';
  }
  nr?.classList.toggle('done', hasAnswer);
}

function hydrateDraftState() {
  Object.entries(answers).forEach(([questionId, value]) => markAnswered(questionId, !!(value && value.trim())));
  updateSummary();
}

async function saveProgress() {
  if (PHOTO_REQUIRED && !PHOTO_SAVED) {
    openPhotoModal();
    return;
  }

  const state = document.getElementById('save-state');
  state.className = 'save-state';
  state.textContent = 'Saving...';

  const fd = new FormData();
  fd.append('__RequestVerificationToken', document.querySelector('input[name=__RequestVerificationToken]').value);
  QUESTIONS.forEach(q => fd.append(`answers[${q.id}]`, answers[q.id] || ''));

  try {
    const res = await fetch('/Interview/SaveProgress', { method: 'POST', body: fd });
    const json = await res.json();
    if (json.success) {
      state.className = 'save-state ok';
      state.textContent = `Saved ${json.savedAt}`;
    } else {
      state.className = 'save-state err';
      state.textContent = json.message || 'Save failed';
    }
  } catch (e) {
    state.className = 'save-state err';
    state.textContent = 'Network save failed';
  }
}

// ── Nav ───────────────────────────────────────────────────────────────────────
function navigate(d) { render(Math.max(0, Math.min(TOTAL - 1, cur + d))); }
function jumpTo(id, i) { render(i); }
function clearAnswer() {
  const q    = QUESTIONS[cur];
  const type = getType(q);
  answers[q.id] = '';
  document.getElementById(`h-${q.id}`).value = '';

  if (type === 'mcq') {
    document.querySelectorAll('.mcq-option').forEach(o => o.classList.remove('selected'));
  } else {
    const ta = document.getElementById('q-input');
    ta.value = '';
    onType(ta);
    return;
  }

  const nd = document.getElementById(`ndot-${q.id}`);
  const nr = document.getElementById(`nav-${q.id}`);
  if (nd) { nd.style.background = ''; nd.style.borderColor = ''; }
  nr?.classList.remove('done');
  updateSummary();
}

// ── Timer ─────────────────────────────────────────────────────────────────────
let secs = 90 * 60;
const timerEl = document.getElementById('tb-timer');
function tick() {
  secs--;
  const m = Math.floor(secs / 60), s = secs % 60;
  document.getElementById('tb-time').textContent = `${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`;
  timerEl.className = 'tb-timer' + (secs < 300 ? ' crit' : secs < 600 ? ' warn' : '');
  if (secs <= 0) { clearInterval(iv); doSubmit(); }
}
const iv = setInterval(tick, 1000);

// ── Confirm / Submit ──────────────────────────────────────────────────────────
function openConfirm() {
  if (PHOTO_REQUIRED && !PHOTO_SAVED) {
    openPhotoModal();
    return;
  }

  const done = Object.values(answers).filter(v => v && v.trim().length > 0).length;
  document.getElementById('cf-ans').textContent  = done;
  document.getElementById('cf-skip').textContent = TOTAL - done;
  document.getElementById('cf-warn').style.display = done < TOTAL ? 'block' : 'none';
  document.getElementById('overlay').classList.add('open');
}
function closeConfirm() { document.getElementById('overlay').classList.remove('open'); }
function doSubmit() {
  if (PHOTO_REQUIRED && !PHOTO_SAVED) {
    openPhotoModal();
    return;
  }

  clearInterval(iv);
  QUESTIONS.forEach(q => {
    const el = document.getElementById(`h-${q.id}`);
    if (el) el.value = answers[q.id] || '';
  });
  document.getElementById('iv-form').submit();
}

document.getElementById('overlay').addEventListener('click', e => {
  if (e.target === e.currentTarget) closeConfirm();
});
document.addEventListener('keydown', e => {
  if (e.altKey && e.key === 'ArrowRight') navigate(1);
  if (e.altKey && e.key === 'ArrowLeft')  navigate(-1);
  if (e.altKey && e.key === 'Enter')      openConfirm();
});

async function openPhotoModal() {
  if (!PHOTO_REQUIRED || PHOTO_SAVED) return;
  document.body.classList.add('capture-required-lock');
  document.getElementById('photo-overlay')?.classList.add('open');
  await startCamera();
}

function showPhotoError(message) {
  const el = document.getElementById('photo-error');
  if (!el) return;
  el.textContent = message;
  el.style.display = 'block';
}

function clearPhotoError() {
  const el = document.getElementById('photo-error');
  if (!el) return;
  el.textContent = '';
  el.style.display = 'none';
}

async function startCamera() {
  clearPhotoError();
  const video = document.getElementById('photo-video');
  if (!video || photoStream) return;

  try {
    photoStream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'user' }, audio: false });
    video.srcObject = photoStream;
  } catch (e) {
    showPhotoError('Camera access is required. Please allow camera permission and try again.');
  }
}

function capturePhoto() {
  clearPhotoError();
  const video = document.getElementById('photo-video');
  const canvas = document.getElementById('photo-canvas');
  if (!video || !canvas || !photoStream) {
    showPhotoError('Camera is not ready yet.');
    return;
  }

  const width = video.videoWidth || 640;
  const height = video.videoHeight || 480;
  canvas.width = width;
  canvas.height = height;
  const ctx = canvas.getContext('2d');
  ctx.drawImage(video, 0, 0, width, height);
  capturedPhotoDataUrl = canvas.toDataURL('image/jpeg', 0.9);
  document.getElementById('photo-save').disabled = false;
  document.getElementById('photo-retake').disabled = false;
}

function retakePhoto() {
  capturedPhotoDataUrl = '';
  const canvas = document.getElementById('photo-canvas');
  if (canvas) canvas.getContext('2d').clearRect(0, 0, canvas.width, canvas.height);
  document.getElementById('photo-save').disabled = true;
  clearPhotoError();
}

async function savePhoto() {
  clearPhotoError();
  const consent = document.getElementById('photo-consent')?.checked;
  if (!consent) {
    showPhotoError('Please accept the consent checkbox before saving.');
    return;
  }

  if (!capturedPhotoDataUrl) {
    showPhotoError('Please capture a photo before saving.');
    return;
  }

  const fd = new FormData();
  fd.append('__RequestVerificationToken', document.querySelector('input[name=__RequestVerificationToken]').value);
  fd.append('photoDataUrl', capturedPhotoDataUrl);
  fd.append('consentAccepted', 'true');

  const btn = document.getElementById('photo-save');
  btn.disabled = true;
  btn.textContent = 'Saving...';

  try {
    const res = await fetch('/Interview/SavePhoto', { method: 'POST', body: fd });
    const json = await res.json();
    if (!json.success) {
      showPhotoError('Photo could not be saved. Please retake and try again.');
      btn.disabled = false;
      btn.textContent = 'Save & Start Test';
      return;
    }

    PHOTO_SAVED = true;
    photoStream?.getTracks().forEach(t => t.stop());
    photoStream = null;
    document.body.classList.remove('capture-required-lock');
    document.getElementById('photo-overlay')?.classList.remove('open');
    document.getElementById('btn-photo-capture')?.remove();
  } catch (e) {
    showPhotoError('Network error while saving photo. Please try again.');
    btn.disabled = false;
    btn.textContent = 'Save & Start Test';
  }
}

render(0);
hydrateDraftState();
if (PHOTO_REQUIRED && !PHOTO_SAVED) {
  window.addEventListener('load', openPhotoModal);
}
</script>
</body>
</html>
