@{ ViewData["Title"] = "Already Submitted"; }

<div style="display:flex;align-items:center;justify-content:center;min-height:calc(100vh - 60px);padding:2rem">
    <div style="text-align:center;max-width:460px">
        <div style="font-size:3.5rem;margin-bottom:1.25rem;line-height:1">🔒</div>
        <h1 style="font-family:var(--font-head);font-size:1.75rem;font-weight:800;letter-spacing:-.5px;margin-bottom:.75rem">
            Already Submitted
        </h1>
        <p style="color:var(--muted);line-height:1.75;margin-bottom:.5rem">
            You have already submitted your interview.
        </p>
        <p style="color:var(--muted);line-height:1.75;margin-bottom:2rem">
            If you believe this is a mistake, please contact your interviewer to request a reset.
        </p>
        <form method="post" action="/Auth/Logout">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-secondary">Sign Out</button>
        </form>
    </div>
</div>
