@model eDrushti_Exam.App.Models.AdminDashboardViewModel
@{
    ViewData["Title"] = "Admin";
    Layout = null;
    var tracks   = ViewBag.Tracks          as List<eDrushti_Exam.App.Models.Track>                              ?? new();
    var topics   = ViewBag.Topics          as List<eDrushti_Exam.App.Models.Topic>                              ?? new();
    var allCands = ViewBag.AllCandidates   as List<eDrushti_Exam.App.Models.Candidate>                          ?? new();
    var allQ     = ViewBag.AllQuestions    as List<eDrushti_Exam.App.Models.Question>                           ?? new();
    var results  = ViewBag.Results         as List<eDrushti_Exam.App.Models.CandidateResultViewModel> ?? new();
    // single token for AJAX calls
}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>Admin — eDrushti Exam</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#f8f9fa;--bg2:#fff;--bg3:#f1f3f5;--bg4:#e9ecef;
  --border:#dee2e6;--border2:#ced4da;
  --text:#1a1a1a;--muted:#6c757d;--dim:#adb5bd;
  --blue:#1971c2;--blue-bg:#e7f5ff;--blue-bd:#a5d8ff;
  --green:#2f9e44;--green-bg:#ebfbee;--green-bd:#b2f2bb;
  --orange:#e67700;--orange-bg:#fff9db;--orange-bd:#ffe066;
  --red:#c92a2a;--red-bg:#fff5f5;--red-bd:#ffc9c9;
  --purple:#6741d9;--purple-bg:#f3f0ff;--purple-bd:#b197fc;
  --nav-w:240px;--hdr:56px;--font:'Inter',sans-serif;
}
html,body{height:100%;overflow:hidden;background:var(--bg);color:var(--text);font-family:var(--font);font-size:14px}

/* ── TOPBAR ─────────────────────────────────────────────────────────────── */
.topbar{position:fixed;top:0;left:0;right:0;height:var(--hdr);z-index:300;background:#fff;border-bottom:1px solid var(--border);display:flex;align-items:center;padding:0 1.5rem;gap:1rem;box-shadow:0 1px 3px rgba(0,0,0,.05)}
.tb-brand{display:flex;align-items:center;gap:.4rem;font-weight:800;font-size:1rem;color:var(--text);width:var(--nav-w);flex-shrink:0}
.tb-brand em{font-style:normal;color:var(--blue)}
.tb-brand-dot{width:8px;height:8px;border-radius:50%;background:var(--blue);flex-shrink:0}
.tb-title{font-size:.85rem;font-weight:600;color:var(--text);flex:1}
.tb-right{display:flex;align-items:center;gap:.75rem}
.tb-user-badge{display:flex;align-items:center;gap:.5rem;font-size:.78rem;color:var(--muted)}
.tb-avatar{width:30px;height:30px;border-radius:50%;background:var(--blue-bg);border:1px solid var(--blue-bd);display:flex;align-items:center;justify-content:center;font-size:.72rem;font-weight:700;color:var(--blue)}
.tb-admin-tag{font-size:.65rem;font-weight:700;padding:2px 8px;border-radius:99px;background:var(--purple-bg);border:1px solid var(--purple-bd);color:var(--purple)}

/* ── SHELL ──────────────────────────────────────────────────────────────── */
.shell{display:grid;grid-template-columns:var(--nav-w) 1fr;height:100vh;padding-top:var(--hdr)}

/* ── SIDENAV ────────────────────────────────────────────────────────────── */
.sidenav{background:#fff;border-right:1px solid var(--border);display:flex;flex-direction:column;overflow-y:auto;padding:1rem 0 0}
.sidenav::-webkit-scrollbar{width:3px}
.sidenav::-webkit-scrollbar-thumb{background:#e9ecef;border-radius:2px}
.nav-group{margin-bottom:.25rem}
.nav-section-label{font-size:.58rem;font-weight:700;text-transform:uppercase;letter-spacing:.12em;color:var(--dim);padding:.65rem 1.1rem .2rem;display:flex;align-items:center;gap:.5rem}
.nav-section-label::after{content:'';flex:1;height:1px;background:var(--border)}
.nav-item{display:flex;align-items:center;gap:.65rem;padding:.5rem .85rem;margin:1px .6rem;font-size:.8rem;font-weight:500;color:var(--muted);cursor:pointer;border:none;border-radius:8px;transition:all .15s;text-decoration:none;background:transparent;width:calc(100% - 1.2rem);text-align:left;font-family:var(--font)}
.nav-item:hover{background:#f1f3f5;color:var(--text)}
.nav-item.active{background:var(--blue-bg);color:var(--blue);font-weight:600}
.nav-item.active .nav-icon-wrap{background:var(--blue);color:#fff}
.nav-icon-wrap{width:26px;height:26px;border-radius:7px;display:flex;align-items:center;justify-content:center;font-size:.82rem;flex-shrink:0;background:#f1f3f5;transition:background .15s,color .15s}
.nav-item:hover .nav-icon-wrap{background:var(--border)}
.nav-badge{margin-left:auto;font-size:.6rem;font-weight:700;padding:1px 7px;border-radius:99px;background:var(--blue-bg);color:var(--blue);border:1px solid var(--blue-bd)}
.nav-item.active .nav-badge{background:rgba(25,113,194,.15);border-color:rgba(25,113,194,.25)}
.nav-sep{height:.35rem}
.nav-bottom{margin-top:auto;padding:.75rem 0;border-top:1px solid var(--border)}
.nav-bottom .nav-item{color:var(--muted)}
.nav-bottom .nav-item:hover{color:var(--text)}

/* ── MAIN ───────────────────────────────────────────────────────────────── */
.main{overflow-y:auto;background:var(--bg)}
.main::-webkit-scrollbar{width:5px}
.main::-webkit-scrollbar-thumb{background:var(--border2);border-radius:3px}
.section{display:none;padding:1.75rem}
.section.active{display:block}
.page-head{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.75rem;margin-bottom:1.5rem}
.page-head h1{font-size:1.25rem;font-weight:700;color:var(--text);letter-spacing:-.3px}
.page-head p{font-size:.8rem;color:var(--muted);margin-top:.15rem}

/* ── STATS ──────────────────────────────────────────────────────────────── */
.stat-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:1rem;margin-bottom:1.75rem}
.stat-card{background:#fff;border:1px solid var(--border);border-radius:10px;padding:1.25rem 1.5rem}
.stat-card-icon{width:36px;height:36px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:1rem;margin-bottom:.75rem}
.stat-card-val{font-size:1.75rem;font-weight:800;line-height:1;margin-bottom:.2rem}
.stat-card-lbl{font-size:.72rem;color:var(--muted);text-transform:uppercase;letter-spacing:.06em;font-weight:500}
.quick-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:1rem;margin-bottom:1.75rem}
.quick-card{background:#fff;border:1px solid var(--border);border-radius:10px;padding:1.25rem;cursor:pointer;transition:border-color .15s,box-shadow .15s}
.quick-card:hover{border-color:var(--blue);box-shadow:0 2px 12px rgba(25,113,194,.08)}
.quick-card-icon{font-size:1.4rem;margin-bottom:.5rem}
.quick-card-title{font-size:.88rem;font-weight:700;color:var(--text);margin-bottom:.2rem}
.quick-card-desc{font-size:.75rem;color:var(--muted)}

/* ── CARD / TABLE ───────────────────────────────────────────────────────── */
.card{background:#fff;border:1px solid var(--border);border-radius:10px}
.card-hdr{display:flex;align-items:center;justify-content:space-between;padding:1rem 1.25rem;border-bottom:1px solid var(--border)}
.card-title{font-size:.9rem;font-weight:700;color:var(--text)}
.card-body{padding:1.25rem}
.card-body-np{padding:0}
.table-wrap{overflow-x:auto}
table{width:100%;border-collapse:collapse}
th{text-align:left;font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--muted);padding:.65rem 1rem;border-bottom:1px solid var(--border);white-space:nowrap;background:#fafafa}
td{padding:.75rem 1rem;border-bottom:1px solid var(--border);font-size:.82rem;vertical-align:middle;color:var(--text)}
tr:last-child td{border-bottom:none}
tr:hover td{background:#fafafa}
.filter-bar{display:flex;gap:.6rem;padding:.85rem 1.25rem;border-bottom:1px solid var(--border);flex-wrap:wrap;align-items:center;background:#fafafa}
.filter-count{font-size:.75rem;color:var(--muted);margin-left:auto}

/* ── BADGES ─────────────────────────────────────────────────────────────── */
.badge{display:inline-block;font-size:.65rem;font-weight:700;padding:2px 8px;border-radius:99px;letter-spacing:.03em;white-space:nowrap}
.badge-java   {background:var(--green-bg);color:var(--green);border:1px solid var(--green-bd)}
.badge-dotnet {background:var(--blue-bg);color:var(--blue);border:1px solid var(--blue-bd)}
.badge-qa     {background:var(--orange-bg);color:var(--orange);border:1px solid var(--orange-bd)}
.badge-active {background:var(--green-bg);color:var(--green);border:1px solid var(--green-bd)}
.badge-off    {background:var(--bg4);color:var(--muted);border:1px solid var(--border)}
.badge-pending{background:#fff9db;color:#7c4a00;border:1px solid #ffe066}
.badge-pass   {background:var(--green-bg);color:var(--green);border:1px solid var(--green-bd)}
.badge-fail   {background:var(--red-bg);color:var(--red);border:1px solid var(--red-bd)}

/* ── BUTTONS ────────────────────────────────────────────────────────────── */
.btn{display:inline-flex;align-items:center;gap:.35rem;padding:.42rem 1rem;border-radius:7px;font-family:var(--font);font-size:.8rem;font-weight:500;cursor:pointer;border:1px solid transparent;transition:all .15s;text-decoration:none;white-space:nowrap}
.btn-primary  {background:var(--blue);color:#fff;border-color:var(--blue)}
.btn-primary:hover{background:#1864ab}
.btn-secondary{background:#fff;color:var(--text);border-color:var(--border2)}
.btn-secondary:hover{background:var(--bg3)}
.btn-green    {background:var(--green);color:#fff;border-color:var(--green)}
.btn-green:hover{background:#2b8a3e}
.btn-danger   {background:#fff;color:var(--red);border-color:var(--red-bd)}
.btn-danger:hover{background:var(--red-bg)}
.btn-info     {background:var(--blue-bg);color:var(--blue);border-color:var(--blue-bd)}
.btn-info:hover{background:#d0ebff}
.btn-orange   {background:var(--orange-bg);color:var(--orange);border-color:var(--orange-bd)}
.btn-orange:hover{background:#ffec99}
.btn-sm{padding:.28rem .65rem;font-size:.72rem}
.btn-xs{padding:.18rem .5rem;font-size:.68rem}

/* ── FORMS ──────────────────────────────────────────────────────────────── */
.form-group{margin-bottom:1rem}
.form-label{display:block;font-size:.72rem;font-weight:600;color:var(--text);margin-bottom:.3rem}
.form-control{width:100%;background:#fff;border:1px solid var(--border2);border-radius:7px;color:var(--text);font-family:var(--font);font-size:.85rem;padding:.58rem .85rem;outline:none;transition:border-color .15s,box-shadow .15s}
.form-control:focus{border-color:var(--blue);box-shadow:0 0 0 3px rgba(25,113,194,.08)}
.form-control::placeholder{color:var(--dim)}
textarea.form-control{resize:vertical;min-height:80px}
select.form-control{cursor:pointer}
.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:0 1rem}
.form-grid .span2{grid-column:1/-1}
.form-hint{color:var(--muted);font-size:.72rem;margin-top:.25rem}
.alert{padding:.65rem .9rem;border-radius:7px;font-size:.8rem;margin-bottom:1rem}
.alert-success{background:var(--green-bg);color:var(--green);border:1px solid var(--green-bd)}
.alert-danger {background:var(--red-bg);color:var(--red);border:1px solid var(--red-bd)}

/* ── MODAL ──────────────────────────────────────────────────────────────── */
.overlay{display:none;position:fixed;inset:0;z-index:500;background:rgba(0,0,0,.4);backdrop-filter:blur(3px);align-items:center;justify-content:center;padding:1.5rem}
.overlay.open{display:flex}
.modal{background:#fff;border:1px solid var(--border);border-radius:12px;width:100%;max-width:560px;max-height:90vh;overflow-y:auto;box-shadow:0 20px 60px rgba(0,0,0,.15);animation:modal-in .18s ease}
.modal.modal-sm{max-width:420px}
.modal.modal-lg{max-width:720px}
@@keyframes modal-in{from{opacity:0;transform:translateY(14px) scale(.97)}to{opacity:1;transform:none}}
.modal-hdr{display:flex;align-items:center;justify-content:space-between;padding:1.1rem 1.4rem;border-bottom:1px solid var(--border);position:sticky;top:0;background:#fff;z-index:1;border-radius:12px 12px 0 0}
.modal-title{font-size:.9rem;font-weight:700;color:var(--text)}
.modal-close{width:26px;height:26px;border-radius:6px;border:1px solid var(--border);background:var(--bg3);color:var(--muted);font-size:.85rem;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .12s}
.modal-close:hover{background:var(--border);color:var(--text)}
.modal-body{padding:1.4rem}
.modal-foot{display:flex;gap:.6rem;justify-content:flex-end;padding:1rem 1.4rem;border-top:1px solid var(--border)}
.modal-err{color:var(--red);font-size:.75rem;background:var(--red-bg);border:1px solid var(--red-bd);border-radius:6px;padding:.45rem .75rem;margin-bottom:.85rem;display:none}

/* delete confirm box */
.del-warn-box{background:var(--red-bg);border:1px solid var(--red-bd);border-radius:8px;padding:.85rem 1rem;display:flex;gap:.65rem;align-items:flex-start}
.del-warn-icon{font-size:1.1rem;flex-shrink:0}
.del-warn-text{font-size:.83rem;color:var(--red);line-height:1.6}
.del-warn-text strong{color:var(--red)}

/* results */
.answer-card{background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:1.1rem;margin-bottom:.85rem}
.answer-q{font-size:.82rem;font-weight:600;color:var(--text);margin-bottom:.5rem;display:flex;gap:.5rem;align-items:flex-start}
.answer-qtag{font-size:.65rem;font-weight:700;color:var(--blue);background:var(--blue-bg);border:1px solid var(--blue-bd);border-radius:4px;padding:1px 7px;flex-shrink:0;margin-top:1px}
.answer-text{font-size:.8rem;color:var(--muted);line-height:1.65;background:#fff;border:1px solid var(--border);border-radius:6px;padding:.65rem .85rem;white-space:pre-wrap;word-break:break-word}

/* assign questions */
.qcheck-group{max-height:260px;overflow-y:auto;border:1px solid var(--border);border-radius:7px;background:var(--bg)}
.qcheck-group::-webkit-scrollbar{width:4px}
.qcheck-group::-webkit-scrollbar-thumb{background:var(--border2);border-radius:2px}
.qcheck-item{display:flex;align-items:flex-start;gap:.6rem;padding:.55rem .85rem;border-bottom:1px solid var(--border);cursor:pointer;transition:background .1s}
.qcheck-item:last-child{border-bottom:none}
.qcheck-item:hover{background:#f8f9fa}
.qcheck-item input{margin-top:2px;accent-color:var(--blue);flex-shrink:0}
.qcheck-item label{font-size:.78rem;color:var(--text);cursor:pointer;line-height:1.45}
.qcheck-meta{font-size:.68rem;color:var(--muted);margin-top:.15rem}
.qcheck-filter{padding:.5rem .85rem;border-bottom:1px solid var(--border);background:#fff}
.qcheck-filter input{width:100%;border:1px solid var(--border);border-radius:5px;padding:.35rem .65rem;font-size:.78rem;outline:none;font-family:var(--font)}
.qcheck-filter input:focus{border-color:var(--blue)}

/* ── TOAST ──────────────────────────────────────────────────────────────── */
#app-toast{
  position:fixed;bottom:1.75rem;right:1.75rem;z-index:9999;
  padding:.7rem 1.1rem;border-radius:9px;font-size:.82rem;font-weight:500;
  max-width:340px;box-shadow:0 4px 20px rgba(0,0,0,.12);
  opacity:0;pointer-events:none;transition:opacity .25s,transform .25s;
  transform:translateY(8px);
}
#app-toast.show{opacity:1;transform:translateY(0)}
</style>
</head>
<body>

<!-- ── CSRF token available to all JS fetch calls ── -->
@Html.AntiForgeryToken()

<!-- ══ TOP BAR ══════════════════════════════════════════════════════════════ -->
<header class="topbar">
  <div class="tb-brand">
    <span class="tb-brand-dot"></span>
    e<em>Drushti</em>&nbsp;Exam
  </div>
  <div class="tb-title" id="tb-section-title">Dashboard</div>
  <div class="tb-right">
    <span class="tb-admin-tag">Admin</span>
    <div class="tb-user-badge">
      <div class="tb-avatar">A</div>
      <span>@User.Identity?.Name</span>
    </div>
    <form method="post" action="/Auth/Logout" style="display:inline">
      @Html.AntiForgeryToken()
      <button type="submit" class="btn btn-secondary btn-sm">Sign out</button>
    </form>
  </div>
</header>

<!-- ══ SHELL ═════════════════════════════════════════════════════════════════ -->
<div class="shell">

  <!-- ── LEFT NAV ─────────────────────────────────────────────────────────── -->
  <nav class="sidenav">
    <div class="nav-group">
      <div class="nav-section-label">Main</div>
      <button class="nav-item active" onclick="showSection('dashboard',this)" data-title="Dashboard">
        <span class="nav-icon-wrap">🏠</span> Dashboard
      </button>
    </div>
    <div class="nav-sep"></div>
    <div class="nav-group">
      <div class="nav-section-label">Masters</div>
      <button class="nav-item" onclick="showSection('candidates',this)" data-title="Candidate Master">
        <span class="nav-icon-wrap">👥</span> Candidates
        <span class="nav-badge" id="nb-candidates">@allCands.Count</span>
      </button>
      <button class="nav-item" onclick="showSection('questions',this)" data-title="Question Master">
        <span class="nav-icon-wrap">📋</span> Questions
        <span class="nav-badge" id="nb-questions">@allQ.Count</span>
      </button>
    </div>
    <div class="nav-sep"></div>
    <div class="nav-group">
      <div class="nav-section-label">Reports</div>
      <button class="nav-item" onclick="showSection('results',this)" data-title="Candidate Results">
        <span class="nav-icon-wrap">📊</span> Results
        <span class="nav-badge" id="nb-results">@results.Count</span>
      </button>
    </div>
    <div class="nav-bottom">
      <button class="nav-item" data-title="Settings">
        <span class="nav-icon-wrap">⚙️</span> Settings
      </button>
    </div>
  </nav>

  <!-- ── MAIN ─────────────────────────────────────────────────────────────── -->
  <div class="main">

    <!-- ════════ DASHBOARD ════════ -->
    <div class="section active" id="section-dashboard">
      <div class="page-head">
        <div><h1>Dashboard</h1><p>Platform overview at a glance</p></div>
        <div style="display:flex;gap:.5rem">
          <button class="btn btn-secondary" onclick="showSection('questions',document.querySelectorAll('.nav-item')[2])">+ Question</button>
          <button class="btn btn-primary"   onclick="showSection('candidates',document.querySelectorAll('.nav-item')[1])">+ Candidate</button>
        </div>
      </div>

      <div class="stat-grid">
        <div class="stat-card">
          <div class="stat-card-icon" style="background:var(--blue-bg)">👥</div>
          <div class="stat-card-val" style="color:var(--blue)">@Model.TotalCandidates</div>
          <div class="stat-card-lbl">Candidates</div>
        </div>
        <div class="stat-card">
          <div class="stat-card-icon" style="background:var(--orange-bg)">📋</div>
          <div class="stat-card-val" style="color:var(--orange)">@Model.TotalQuestions</div>
          <div class="stat-card-lbl">Questions</div>
        </div>
        <div class="stat-card">
          <div class="stat-card-icon" style="background:var(--green-bg)">✅</div>
          <div class="stat-card-val" style="color:var(--green)">@Model.TotalSubmissions</div>
          <div class="stat-card-lbl">Submissions</div>
        </div>
        <div class="stat-card">
          <div class="stat-card-icon" style="background:var(--purple-bg)">🏷️</div>
          <div class="stat-card-val" style="color:var(--purple)">@Model.TotalTracks</div>
          <div class="stat-card-lbl">Tracks</div>
        </div>
      </div>

      <div class="quick-grid">
        <div class="quick-card" onclick="showSection('candidates',document.querySelectorAll('.nav-item')[1])">
          <div class="quick-card-icon">👥</div>
          <div class="quick-card-title">Candidate Master</div>
          <div class="quick-card-desc">Add, edit, delete candidates and assign tracks</div>
        </div>
        <div class="quick-card" onclick="showSection('questions',document.querySelectorAll('.nav-item')[2])">
          <div class="quick-card-icon">📋</div>
          <div class="quick-card-title">Question Master</div>
          <div class="quick-card-desc">Manage questions and assign to candidates</div>
        </div>
        <div class="quick-card" onclick="showSection('results',document.querySelectorAll('.nav-item')[4])">
          <div class="quick-card-icon">📊</div>
          <div class="quick-card-title">View Results</div>
          <div class="quick-card-desc">Review answers, scores, and final status</div>
        </div>
      </div>

      <div class="card">
        <div class="card-hdr">
          <span class="card-title">Recent Candidates</span>
          <button class="btn btn-secondary btn-sm" onclick="showSection('candidates',document.querySelectorAll('.nav-item')[1])">View all →</button>
        </div>
        <div class="card-body-np table-wrap">
          <table>
            <thead><tr><th>Name</th><th>Track</th><th>Status</th><th>Submitted</th><th>Added</th></tr></thead>
            <tbody>
              @foreach (var c in Model.RecentCandidates)
              {
                <tr>
                  <td style="font-weight:500">@c.FullName</td>
                  <td><span class="badge badge-@(c.Track?.Slug??"")">@(c.Track?.Name??"—")</span></td>
                  <td><span class="badge @(c.IsActive?"badge-active":"badge-off")">@(c.IsActive?"Active":"Inactive")</span></td>
                  <td>@Html.Raw(c.Answers.Any()?"<span class='badge badge-active'>Yes</span>":"<span class='badge badge-pending'>Pending</span>")</td>
                  <td style="color:var(--muted);font-size:.75rem">@c.CreatedAt.ToString("dd MMM yyyy")</td>
                </tr>
              }
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- ════════ CANDIDATES ════════ -->
    <div class="section" id="section-candidates">
      <div class="page-head">
        <div><h1>Candidate Master</h1><p>Manage all candidates and their assigned tracks</p></div>
        <button class="btn btn-primary" onclick="openModal('c-add-modal')">+ Add Candidate</button>
      </div>
      <div class="card">
        <div class="filter-bar">
          <input id="c-search" class="form-control" style="max-width:240px;padding:.38rem .75rem;font-size:.78rem" placeholder="Search name…" oninput="filterCands()"/>
          <select id="c-track-f" class="form-control" style="max-width:140px;padding:.38rem .65rem;font-size:.78rem" onchange="filterCands()">
            <option value="">All tracks</option>
            @foreach (var t in tracks) { <option value="@t.Slug">@t.Name</option> }
          </select>
          <select id="c-status-f" class="form-control" style="max-width:130px;padding:.38rem .65rem;font-size:.78rem" onchange="filterCands()">
            <option value="">All status</option>
            <option value="active">Active</option>
            <option value="inactive">Inactive</option>
          </select>
          <span class="filter-count" id="c-count"></span>
        </div>
        <div class="card-body-np table-wrap">
          <table id="c-table">
            <thead><tr><th>#</th><th>Name</th><th>Phone</th><th>Track</th><th>Status</th><th>Submitted</th><th>Added</th><th>Actions</th></tr></thead>
            <tbody>
              @{ int ci=1; }
              @foreach (var c in allCands)
              {
                var slug = c.Track?.Slug ?? "";
                <tr data-name="@c.FullName.ToLower()" data-track="@slug" data-status="@(c.IsActive?"active":"inactive")">
                  <td style="color:var(--dim);font-size:.72rem">@(ci++)</td>
                  <td style="font-weight:600">@c.FullName</td>
                  <td style="color:var(--muted)">@(c.Phone??"—")</td>
                  <td><span class="badge badge-@slug">@(c.Track?.Name??"—")</span></td>
                  <td><span class="badge @(c.IsActive?"badge-active":"badge-off")">@(c.IsActive?"Active":"Inactive")</span></td>
                  <td>@Html.Raw(c.Answers.Any()?"<span class='badge badge-active'>Yes</span>":"<span class='badge badge-pending'>Pending</span>")</td>
                  <td style="color:var(--muted);font-size:.72rem;white-space:nowrap">@c.CreatedAt.ToString("dd MMM yyyy")</td>
                  <td>
                    <div style="display:flex;gap:.3rem;flex-wrap:wrap">
                      <button class="btn btn-info btn-xs"   onclick="openEditCandidate(@c.Id)">Edit</button>
                      <button class="btn btn-orange btn-xs" onclick="openAssignModal(@c.Id,'@Html.Raw(c.FullName.Replace("'","\\'"))')">Assign Q</button>
                      @if (c.Answers.Any()) {
                        <button class="btn btn-secondary btn-xs" onclick="openResultModal(@c.Id)">Results</button>
                      }
                      <button class="btn btn-danger btn-xs" onclick="openDelCand(@c.Id,'@Html.Raw(c.FullName.Replace("'","\\'"))')">Delete</button>
                    </div>
                  </td>
                </tr>
              }
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- ════════ QUESTIONS ════════ -->
    <div class="section" id="section-questions">
      <div class="page-head">
        <div><h1>Question Master</h1><p>Manage all questions across tracks and topics</p></div>
        <button class="btn btn-primary" onclick="openModal('q-add-modal')">+ Add Question</button>
      </div>
      <div class="card">
        <div class="filter-bar">
          <input id="q-search" class="form-control" style="max-width:280px;padding:.38rem .75rem;font-size:.78rem" placeholder="Search question…" oninput="filterQ()"/>
          <select id="q-track-f" class="form-control" style="max-width:140px;padding:.38rem .65rem;font-size:.78rem" onchange="filterQ()">
            <option value="">All tracks</option>
            @foreach (var t in tracks) { <option value="@t.Id">@t.Name</option> }
          </select>
          <select id="q-status-f" class="form-control" style="max-width:130px;padding:.38rem .65rem;font-size:.78rem" onchange="filterQ()">
            <option value="">All status</option>
            <option value="active">Active</option>
            <option value="inactive">Inactive</option>
          </select>
          <span class="filter-count" id="q-count"></span>
        </div>
        <div class="card-body-np table-wrap">
          <table id="q-table">
            <thead><tr><th>#</th><th>Question</th><th>Track</th><th>Topic</th><th>Order</th><th>Status</th><th>Actions</th></tr></thead>
            <tbody>
              @{ int qi=1; }
              @foreach (var q in allQ)
              {
                var tslug = q.Topic?.Track?.Slug ?? "";
                <tr data-text="@q.QuestionText.ToLower()" data-trackid="@(q.Topic?.Track?.Id)" data-status="@(q.IsActive?"active":"inactive")">
                  <td style="color:var(--dim);font-size:.72rem">@(qi++)</td>
                  <td style="max-width:380px">
                    <div style="font-size:.8rem;line-height:1.45">@q.QuestionText</div>
                    @if (!string.IsNullOrWhiteSpace(q.HintText))
                    { <div style="font-size:.7rem;color:var(--muted);margin-top:.2rem">💡 @q.HintText</div> }
                  </td>
                  <td><span class="badge badge-@tslug">@(q.Topic?.Track?.Name??"—")</span></td>
                  <td style="color:var(--muted);font-size:.75rem">@(q.Topic?.Name??"—")</td>
                  <td style="color:var(--muted);text-align:center">@q.OrderIndex</td>
                  <td><span class="badge @(q.IsActive?"badge-active":"badge-off")">@(q.IsActive?"Active":"Off")</span></td>
                  <td>
                    <div style="display:flex;gap:.3rem">
                      <button class="btn btn-info btn-xs"   onclick="openEditQ(@q.Id)">Edit</button>
                      <button class="btn btn-danger btn-xs" onclick="openDelQ(@q.Id,'@Html.Raw(q.QuestionText.Substring(0,Math.Min(50,q.QuestionText.Length)).Replace("'","\\'"))')">Delete</button>
                    </div>
                  </td>
                </tr>
              }
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- ════════ RESULTS ════════ -->
    <div class="section" id="section-results">
      <div class="page-head">
        <div><h1>Candidate Results</h1><p>Review submitted answers, scores, and final status</p></div>
      </div>
      <div class="card">
        <div class="filter-bar">
          <input id="r-search" class="form-control" style="max-width:240px;padding:.38rem .75rem;font-size:.78rem" placeholder="Search candidate…" oninput="filterR()"/>
          <select id="r-track-f" class="form-control" style="max-width:140px;padding:.38rem .65rem;font-size:.78rem" onchange="filterR()">
            <option value="">All tracks</option>
            @foreach (var t in tracks) { <option value="@t.Slug">@t.Name</option> }
          </select>
          <span class="filter-count" id="r-count"></span>
        </div>
        <div class="card-body-np table-wrap">
          <table id="r-table">
            <thead><tr><th>#</th><th>Candidate</th><th>Track</th><th>Answers</th><th>Score</th><th>Submitted</th><th>Status</th><th>Actions</th></tr></thead>
            <tbody>
              @{ int ri=1; }
              @foreach (var r in results)
              {
                <tr data-name="@r.FullName.ToLower()" data-track="@r.TrackSlug">
                  <td style="color:var(--dim);font-size:.72rem">@(ri++)</td>
                  <td style="font-weight:600">@r.FullName</td>
                  <td><span class="badge badge-@r.TrackSlug">@r.TrackName</span></td>
                  <td style="font-weight:700;color:var(--blue)">@r.TotalAnswers</td>
                  <td style="font-weight:700;color:@(r.ResultStatus == "Pass" ? "var(--green)" : "var(--red)")">@(r.ScorePercent?.ToString("0.##") ?? "0")%</td>
                  <td style="color:var(--muted);font-size:.72rem;white-space:nowrap">@r.SubmittedAt.ToString("dd MMM yyyy, HH:mm")</td>
                  <td id="decision-@r.CandidateId"><span class="badge badge-@(r.ResultStatus == "Pass" ? "pass" : "fail")">@r.ResultStatus</span></td>
                  <td>
                    <div style="display:flex;gap:.3rem;flex-wrap:wrap">
                      <button class="btn btn-info btn-xs"    onclick="openResultModal(@r.CandidateId)">View Answers</button>
                      <a class="btn btn-secondary btn-xs" href="/Admin/Results/@r.CandidateId/Pdf">PDF</a>
                    </div>
                  </td>
                </tr>
              }
            </tbody>
          </table>
        </div>
      </div>
    </div>

  </div><!-- /main -->
</div><!-- /shell -->

