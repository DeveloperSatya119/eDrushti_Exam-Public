<!-- ════════════════ TOAST ════════════════ -->
<div id="app-toast"></div>

<script>
// ── CSRF token (used by all fetch POSTs) ──────────────────────────────────────
const CSRF = () => document.querySelector('input[name=__RequestVerificationToken]').value;

// ── Toast ─────────────────────────────────────────────────────────────────────
function toast(msg, type = 'success') {
  const el = document.getElementById('app-toast');
  el.textContent = (type === 'success' ? '✓  ' : '✕  ') + msg;
  el.style.background = type === 'success' ? 'var(--green-bg)' : 'var(--red-bg)';
  el.style.color      = type === 'success' ? 'var(--green)'    : 'var(--red)';
  el.style.border     = type === 'success' ? '1px solid var(--green-bd)' : '1px solid var(--red-bd)';
  el.classList.add('show');
  clearTimeout(el._t);
  el._t = setTimeout(() => el.classList.remove('show'), 3000);
}

// ── Section navigation ────────────────────────────────────────────────────────
function showSection(id, navEl) {
  document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  document.getElementById('section-' + id)?.classList.add('active');
  if (navEl) navEl.classList.add('active');
  document.getElementById('tb-section-title').textContent = navEl?.dataset?.title || id;
}

// ── Modal helpers ─────────────────────────────────────────────────────────────
function openModal(id)  { document.getElementById(id)?.classList.add('open');    document.body.style.overflow = 'hidden'; }
function closeModal(id) { document.getElementById(id)?.classList.remove('open'); document.body.style.overflow = ''; }
document.addEventListener('click',   e => { if (e.target.classList.contains('overlay')) { e.target.classList.remove('open'); document.body.style.overflow = ''; }});
document.addEventListener('keydown', e => { if (e.key === 'Escape') { document.querySelectorAll('.overlay.open').forEach(m => { m.classList.remove('open'); document.body.style.overflow = ''; }); }});

// ── Generic AJAX form submit (used by Add / Edit) ─────────────────────────────
async function submitModal(formId, errId, successMsg, onSuccess) {
  const form = document.getElementById(formId);
  const err  = document.getElementById(errId);
  err.style.display = 'none';
  try {
    const res  = await fetch(form.action, { method: 'POST', body: new FormData(form) });
    const json = await res.json();
    if (json.success) {
      closeModal(form.closest('.overlay')?.id);
      toast(successMsg, 'success');
      setTimeout(onSuccess, 600);
    } else {
      err.textContent = (json.errors || ['An error occurred.']).join(' ');
      err.style.display = 'block';
    }
  } catch(e) {
    err.textContent = 'Network error. Please try again.';
    err.style.display = 'block';
  }
}

// ── Generic AJAX delete (fetch POST, no page navigation) ─────────────────────
async function fetchDelete(url, onSuccess) {
  const fd = new FormData();
  fd.append('__RequestVerificationToken', CSRF());
  try {
    const res  = await fetch(url, { method: 'POST', body: fd });
    const json = await res.json();
    if (json.success) { onSuccess(); }
    else { toast(json.message || 'Delete failed.', 'error'); }
  } catch(e) { toast('Network error. Please try again.', 'error'); }
}

// ── Filter tables ─────────────────────────────────────────────────────────────
function filterCands() {
  const txt = document.getElementById('c-search').value.toLowerCase();
  const trk = document.getElementById('c-track-f').value;
  const sts = document.getElementById('c-status-f').value;
  let v = 0;
  document.querySelectorAll('#c-table tbody tr').forEach(r => {
    const ok = (!txt || r.dataset.name.includes(txt)) && (!trk || r.dataset.track === trk) && (!sts || r.dataset.status === sts);
    r.style.display = ok ? '' : 'none'; if (ok) v++;
  });
  document.getElementById('c-count').textContent = v + ' shown';
}
function filterQ() {
  const txt = document.getElementById('q-search').value.toLowerCase();
  const trk = document.getElementById('q-track-f').value;
  const sts = document.getElementById('q-status-f').value;
  let v = 0;
  document.querySelectorAll('#q-table tbody tr').forEach(r => {
    const ok = (!txt || (r.dataset.text || '').includes(txt)) && (!trk || r.dataset.trackid === trk) && (!sts || r.dataset.status === sts);
    r.style.display = ok ? '' : 'none'; if (ok) v++;
  });
  document.getElementById('q-count').textContent = v + ' shown';
}
function filterR() {
  const txt = document.getElementById('r-search').value.toLowerCase();
  const trk = document.getElementById('r-track-f').value;
  let v = 0;
  document.querySelectorAll('#r-table tbody tr').forEach(r => {
    const ok = (!txt || r.dataset.name.includes(txt)) && (!trk || r.dataset.track === trk);
    r.style.display = ok ? '' : 'none'; if (ok) v++;
  });
  document.getElementById('r-count').textContent = v + ' shown';
}

// ── Topic cascade ─────────────────────────────────────────────────────────────
function cascadeTopics(trackSelId, topicSelId) {
  const trk = document.getElementById(trackSelId).value;
  const sel = document.getElementById(topicSelId);
  let first = true;
  sel.querySelectorAll('option').forEach(o => {
    if (!o.value) return;
    const show = !trk || o.dataset.track === trk;
    o.style.display = show ? '' : 'none';
    if (show && first) { sel.value = o.value; first = false; }
  });
  if (!trk) sel.value = '';
}

// ── CANDIDATE: Edit ───────────────────────────────────────────────────────────
async function openEditCandidate(id) {
  const res = await fetch(`/Admin/Candidates/GetJson/${id}`);
  const d   = await res.json();
  document.getElementById('ec-id').value     = d.id;
  document.getElementById('ec-name').value   = d.fullName;
  document.getElementById('ec-email').value  = d.email;
  document.getElementById('ec-phone').value  = d.phone || '';
  document.getElementById('ec-track').value  = d.trackId;
  document.getElementById('ec-active').value = d.isActive ? 'true' : 'false';
  openModal('c-edit-modal');
}

// ── CANDIDATE: Delete ─────────────────────────────────────────────────────────
let _delCandId = null;
function openDelCand(id, name) {
  _delCandId = id;
  document.getElementById('del-c-name').textContent = name;
  openModal('c-del-modal');
}
document.getElementById('c-del-confirm-btn').addEventListener('click', () => {
  if (!_delCandId) return;
  closeModal('c-del-modal');
  fetchDelete(`/Admin/Candidates/Delete/${_delCandId}`, () => {
    toast('Candidate deleted successfully.', 'success');
    setTimeout(() => location.reload(), 800);
  });
  _delCandId = null;
});

// ── CANDIDATE: Assign questions ───────────────────────────────────────────────
function openAssignModal(candidateId, name) {
  document.getElementById('assign-cid').value           = candidateId;
  document.getElementById('assign-cname').textContent   = name;
  document.getElementById('assign-track-f').value       = '';
  document.getElementById('assign-q-search').value      = '';
  filterAssignQ('');
  document.querySelectorAll('#qcheck-list input[type=checkbox]').forEach(c => c.checked = false);
  updateAssignCount();
  openModal('c-assign-modal');
}
function filterAssignQ(trackId) {
  document.querySelectorAll('.qcheck-item').forEach(item => {
    item.style.display = !trackId || item.dataset.trackid === trackId ? '' : 'none';
  });
}
function searchAssignQ(txt) {
  const q = txt.toLowerCase();
  document.querySelectorAll('.qcheck-item').forEach(item => {
    item.style.display = (!q || (item.dataset.text || '').includes(q)) ? '' : 'none';
  });
}
function selectAllQ(state) {
  document.querySelectorAll('.qcheck-item:not([style*="none"]) input[type=checkbox]').forEach(c => c.checked = state);
  updateAssignCount();
}
function updateAssignCount() {
  const n = document.querySelectorAll('#qcheck-list input:checked').length;
  document.getElementById('assign-count').textContent = n + ' selected';
}

// ── QUESTION: Edit ────────────────────────────────────────────────────────────
async function openEditQ(id) {
  const res = await fetch(`/Admin/Questions/GetJson/${id}`);
  const d   = await res.json();
  document.getElementById('eq-id').value     = d.id;
  document.getElementById('eq-text').value   = d.questionText;
  document.getElementById('eq-hint').value   = d.hintText || '';
  document.getElementById('eq-order').value  = d.orderIndex;
  document.getElementById('eq-active').value = d.isActive ? 'true' : 'false';
  const ts = document.getElementById('eq-track-sel');
  ts.value = d.trackId || '';
  cascadeTopics('eq-track-sel', 'eq-topic-sel');
  document.getElementById('eq-topic-sel').value = d.topicId;
  openModal('q-edit-modal');
}

// ── QUESTION: Delete ──────────────────────────────────────────────────────────
