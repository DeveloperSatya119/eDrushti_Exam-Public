// ── RESULTS: View answers ─────────────────────────────────────────────────────
async function openResultModal(candidateId) {
  openModal('result-modal');
  const body = document.getElementById('rm-body');
  body.innerHTML = '<div style="text-align:center;padding:2rem;color:var(--muted)">Loading answers…</div>';
  try {
    const res  = await fetch(`/Admin/Results/${candidateId}/Json`);
    const data = await res.json();
    document.getElementById('rm-name').textContent = data.fullName;
    let html = `<div style="display:flex;align-items:center;gap:.75rem;margin-bottom:1.1rem;flex-wrap:wrap">
      <span class="badge badge-${data.trackSlug}">${data.trackName}</span>
      <span style="font-size:.75rem;color:var(--muted);margin-left:auto">${data.totalAnswers} answers submitted</span>
      <span class="badge badge-${data.resultStatus === 'Pass' ? 'pass' : 'fail'}">${data.resultStatus} - ${data.scorePercent}%</span>
      <a class="btn btn-secondary btn-xs" href="/Admin/Results/${candidateId}/Pdf">Download PDF</a>
    </div>`;
    data.answers.forEach((a, i) => {
      const isMcq = (a.questionType || '').toLowerCase() === 'mcq';
      const correctness = isMcq
        ? `<span class="badge badge-${a.isCorrect ? 'pass' : 'fail'}">${a.isCorrect ? 'Correct' : 'Incorrect'}</span>
           <span style="font-size:.72rem;color:var(--muted)">Correct answer: ${escHtml(a.correctAnswer || '-')}</span>`
        : '';
      html += `<div class="answer-card">
        <div class="answer-q"><span class="answer-qtag">Q${i+1}</span>${escHtml(a.questionText)}</div>
        <div class="answer-text">${a.answerText ? escHtml(a.answerText) : '<em style="color:var(--dim)">No answer provided</em>'}</div>
        <div style="display:flex;gap:.5rem;margin-top:.55rem;align-items:center;flex-wrap:wrap">${correctness}</div>
      </div>`;
    });
    body.innerHTML = html;
  } catch(e) {
    body.innerHTML = '<div style="color:var(--red);padding:1rem">Failed to load answers.</div>';
  }
}
function escHtml(s) {
  return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

// ── Init ──────────────────────────────────────────────────────────────────────
filterCands(); filterQ(); filterR();
</script>
</body>
</html>
