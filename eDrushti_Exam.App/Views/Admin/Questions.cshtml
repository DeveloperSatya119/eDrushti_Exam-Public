@model List<eDrushti_Exam.App.Models.Question>
@{
    ViewData["Title"] = "Questions";
    var tracks = ViewBag.Tracks as List<eDrushti_Exam.App.Models.Track> ?? new();
    var topics = ViewBag.Topics as List<eDrushti_Exam.App.Models.Topic> ?? new();
}

<div class="page">

    <!-- ── Page header ── -->
    <div class="flex-between page-head">
        <div>
            <h1>Questions</h1>
            <p>@Model.Count question(s) across all tracks</p>
        </div>
        <button class="btn btn-primary" onclick="openModal('q-add-modal')">+ Add Question</button>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">✓ @TempData["Success"]</div>
    }

    <!-- ── Filters ── -->
    <div style="display:flex;gap:.75rem;margin-bottom:1.25rem;flex-wrap:wrap;align-items:center">
        <input id="q-search" class="form-control" style="max-width:280px"
               placeholder="Search question text…" oninput="filterQ()" />
        <select id="q-track-f" class="form-control" style="max-width:160px" onchange="filterQ()">
            <option value="">All tracks</option>
            @foreach (var t in tracks)
            {
                <option value="@t.Id">@t.Name</option>
            }
        </select>
        <select id="q-status-f" class="form-control" style="max-width:140px" onchange="filterQ()">
            <option value="">All status</option>
            <option value="active">Active</option>
            <option value="inactive">Inactive</option>
        </select>
        <span id="q-count" class="text-muted" style="font-size:.82rem"></span>
    </div>

    <!-- ── Table ── -->
    <div class="card" style="padding:0">
        <div class="table-wrap">
            <table id="q-table">
                <thead>
                    <tr>
                        <th style="width:40px">#</th>
                        <th>Question</th>
                        <th>Track</th>
                        <th>Topic</th>
                        <th style="width:60px">Order</th>
                        <th style="width:80px">Status</th>
                        <th style="width:120px">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" style="text-align:center;padding:3rem;color:var(--muted)">
                                No questions yet.
                                <a href="#" style="color:var(--accent)" onclick="openModal('q-add-modal');return false;">Add one →</a>
                            </td>
                        </tr>
                    }
                    @{
                        int qi = 1;
                    }
                    @foreach (var q in Model)
                    {
                        var slug = q.Topic?.Track?.Slug ?? "";
                        var status = q.IsActive ? "active" : "inactive";
                        <tr data-text="@q.QuestionText.ToLower()"
                            data-trackid="@(q.Topic?.Track?.Id)"
                            data-status="@status">
                            <td class="text-muted" style="font-size:.78rem">@(qi++)</td>
                            <td style="max-width:420px">
                                <div style="font-size:.875rem;line-height:1.5;color:var(--text)">@q.QuestionText</div>
                                @if (!string.IsNullOrWhiteSpace(q.HintText))
                                {
                                    <div style="font-size:.75rem;color:var(--muted);margin-top:.25rem">
                                        💡 @q.HintText
                                    </div>
                                }
                            </td>
                            <td><span class="badge badge-@slug">@(q.Topic?.Track?.Name ?? "—")</span></td>
                            <td class="text-muted" style="font-size:.82rem;white-space:nowrap">@(q.Topic?.Name ?? "—")</td>
                            <td class="text-muted" style="font-size:.82rem;text-align:center">@q.OrderIndex</td>
                            <td>
                                <span class="badge @(q.IsActive ? "badge-active" : "badge-off")">
                                    @(q.IsActive ? "Active" : "Off")
                                </span>
                            </td>
                            <td>
                                <div style="display:flex;gap:.35rem">
                                    <button class="btn btn-secondary btn-sm"
                                            onclick="openEditQuestion(@q.Id)">
                                        Edit
                                    </button>
                                    <button class="btn btn-danger btn-sm"
                                            onclick="openDeleteQuestion(@q.Id, @Html.Raw($"'{q.QuestionText.Replace("'", "\\'")}'"))">
                                        Del
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- ════════════════════════════════════════════════════
     ADD QUESTION MODAL
═════════════════════════════════════════════════════ -->
<div class="modal-backdrop" id="q-add-modal">
    <div class="modal">
        <div class="modal-header">
            <span class="modal-title">Add Question</span>
            <button class="modal-close" onclick="closeModal('q-add-modal')">✕</button>
        </div>
        <form id="q-add-form" action="/Admin/Questions/Create" method="post">
            @Html.AntiForgeryToken()
            <div class="modal-body">
                <div id="q-add-err" class="modal-error"></div>

                <div class="form-grid">
                    <div class="form-group">
                        <label class="form-label">Track</label>
                        <select class="form-control" id="add-track-sel"
                                onchange="cascadeTopics('add-track-sel','add-topic-sel')">
                            <option value="">— Select track —</option>
                            @foreach (var t in tracks)
                            {
                                <option value="@t.Id">@t.Name</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Topic <span style="color:var(--danger)">*</span></label>
                        <select class="form-control" name="TopicId" id="add-topic-sel" required>
                            <option value="">— Select topic —</option>
                            @foreach (var t in topics)
                            {
                                <option value="@t.Id" data-track="@t.TrackId">@t.Name</option>
                            }
                        </select>
                    </div>

                    <div class="form-group span2">
                        <label class="form-label">Question text <span style="color:var(--danger)">*</span></label>
                        <textarea class="form-control" name="QuestionText" rows="4"
                                  placeholder="e.g. Explain the difference between abstract class and interface in Java."
                                  maxlength="2000" required minlength="10"></textarea>
                    </div>

                    <div class="form-group span2">
                        <label class="form-label">Hint <span style="color:var(--muted);font-weight:400">(optional)</span></label>
                        <input class="form-control" name="HintText" maxlength="500"
                               placeholder="Short tip shown to the candidate" />
                    </div>

                    <div class="form-group">
                        <label class="form-label">Display order</label>
                        <input class="form-control" name="OrderIndex" type="number" min="1" value="1" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Status</label>
                        <select class="form-control" name="IsActive">
                            <option value="true">Active — visible to candidates</option>
                            <option value="false">Inactive — hidden</option>
                        </select>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="closeModal('q-add-modal')">Cancel</button>
                <button type="button" class="btn btn-primary"
                        onclick="submitModal('q-add-form','q-add-err',()=>location.reload())">
                    Add Question
                </button>
            </div>
        </form>
    </div>
</div>

<!-- ════════════════════════════════════════════════════
     EDIT QUESTION MODAL
═════════════════════════════════════════════════════ -->
<div class="modal-backdrop" id="q-edit-modal">
    <div class="modal">
        <div class="modal-header">
            <span class="modal-title">Edit Question</span>
            <button class="modal-close" onclick="closeModal('q-edit-modal')">✕</button>
        </div>
        <form id="q-edit-form" action="/Admin/Questions/Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="Id" id="edit-q-id" />
            <div class="modal-body">
                <div id="q-edit-err" class="modal-error"></div>

                <div class="form-grid">
                    <div class="form-group">
                        <label class="form-label">Track</label>
                        <select class="form-control" id="edit-track-sel"
                                onchange="cascadeTopics('edit-track-sel','edit-topic-sel')">
                            <option value="">— Select track —</option>
                            @foreach (var t in tracks)
                            {
                                <option value="@t.Id">@t.Name</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Topic <span style="color:var(--danger)">*</span></label>
                        <select class="form-control" name="TopicId" id="edit-topic-sel" required>
                            @foreach (var t in topics)
                            {
                                <option value="@t.Id" data-track="@t.TrackId">@t.Name</option>
                            }
                        </select>
                    </div>

                    <div class="form-group span2">
                        <label class="form-label">Question text <span style="color:var(--danger)">*</span></label>
                        <textarea class="form-control" name="QuestionText" id="edit-q-text"
                                  rows="4" maxlength="2000" required minlength="10"></textarea>
                    </div>

                    <div class="form-group span2">
                        <label class="form-label">Hint <span style="color:var(--muted);font-weight:400">(optional)</span></label>
                        <input class="form-control" name="HintText" id="edit-q-hint" maxlength="500" />
                    </div>

                    <div class="form-group">
                        <label class="form-label">Display order</label>
                        <input class="form-control" name="OrderIndex" id="edit-q-order" type="number" min="1" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Status</label>
                        <select class="form-control" name="IsActive" id="edit-q-active">
                            <option value="true">Active</option>
                            <option value="false">Inactive</option>
                        </select>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="closeModal('q-edit-modal')">Cancel</button>
                <button type="button" class="btn btn-primary"
                        onclick="submitModal('q-edit-form','q-edit-err',()=>location.reload())">
                    Save Changes
                </button>
            </div>
        </form>
    </div>
</div>

<!-- ════════════════════════════════════════════════════
     DELETE CONFIRM MODAL
═════════════════════════════════════════════════════ -->
<div class="modal-backdrop" id="q-del-modal">
    <div class="modal" style="max-width:440px">
        <div class="modal-header">
            <span class="modal-title" style="color:var(--danger)">Delete Question</span>
            <button class="modal-close" onclick="closeModal('q-del-modal')">✕</button>
        </div>
        <div class="modal-body">
            <p style="color:var(--muted);font-size:.9rem;line-height:1.65">
                Are you sure you want to delete this question?
            </p>
            <div id="del-q-preview"
                 style="margin-top:.85rem;padding:.85rem;background:var(--bg3);border:1px solid var(--border);
                        border-radius:8px;font-size:.85rem;color:var(--text);line-height:1.5">
            </div>
            <p style="color:var(--danger);font-size:.8rem;margin-top:.75rem">
                ⚠ This cannot be undone.
            </p>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn btn-secondary" onclick="closeModal('q-del-modal')">Cancel</button>
            <form id="q-del-form" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-danger">Yes, Delete</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // ── Filter ────────────────────────────────────────────────────────────────────
        function filterQ() {
            const txt    = document.getElementById('q-search').value.toLowerCase();
            const trackId = document.getElementById('q-track-f').value;
            const status  = document.getElementById('q-status-f').value;
            let visible = 0;
            document.querySelectorAll('#q-table tbody tr[data-text]').forEach(row => {
                const m1 = !txt     || (row.dataset.text || '').includes(txt);
                const m2 = !trackId || row.dataset.trackid === trackId;
                const m3 = !status  || row.dataset.status  === status;
                const show = m1 && m2 && m3;
                row.style.display = show ? '' : 'none';
                if (show) visible++;
            });
            document.getElementById('q-count').textContent = `${visible} shown`;
        }

        // ── Track → Topic cascade ─────────────────────────────────────────────────────
        function cascadeTopics(trackSelId, topicSelId) {
            const trackId  = document.getElementById(trackSelId).value;
            const topicSel = document.getElementById(topicSelId);
            let first = true;
            topicSel.querySelectorAll('option').forEach(opt => {
                if (!opt.value) return;
                const show = !trackId || opt.dataset.track === trackId;
                opt.style.display = show ? '' : 'none';
                if (show && first) { topicSel.value = opt.value; first = false; }
            });
            if (!trackId) topicSel.value = '';
        }

        // ── Open Edit modal ───────────────────────────────────────────────────────────
        async function openEditQuestion(id) {
            const res  = await fetch(`/Admin/Questions/GetJson/${id}`);
            if (!res.ok) { alert('Could not load question.'); return; }
            const d = await res.json();

            document.getElementById('edit-q-id').value     = d.id;
            document.getElementById('edit-q-text').value   = d.questionText;
            document.getElementById('edit-q-hint').value   = d.hintText  || '';
            document.getElementById('edit-q-order').value  = d.orderIndex;
            document.getElementById('edit-q-active').value = d.isActive ? 'true' : 'false';

            // set track, cascade topics, then set topic
            const trackSel = document.getElementById('edit-track-sel');
            trackSel.value = d.trackId || '';
            cascadeTopics('edit-track-sel', 'edit-topic-sel');
            document.getElementById('edit-topic-sel').value = d.topicId;

            openModal('q-edit-modal');
        }

        // ── Open Delete confirm modal ─────────────────────────────────────────────────
        function openDeleteQuestion(id, text) {
            document.getElementById('del-q-preview').textContent = text;
            document.getElementById('q-del-form').action = `/Admin/Questions/Delete/${id}`;
            openModal('q-del-modal');
        }

        filterQ(); // init count
    </script>
}
